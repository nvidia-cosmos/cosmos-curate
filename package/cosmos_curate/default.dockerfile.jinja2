# syntax=docker/dockerfile:1
# Dockerfile template for cosmos-curate
#
# The dockerfile is templated so that we can provide different conda env information.
# Docs on docker best practices:
# - https://linuxhandbook.com/dockerize-python-apps/
# - https://uwekorn.com/2021/03/01/deploying-conda-environments-in-docker-how-to-do-it-right.html
# - https://cloud.google.com/architecture/best-practices-for-building-containers

ARG DEBIAN_FRONTEND=noninteractive

# ---------------------------------------------------------------------------
# Builder stage: compile ffmpeg from source
# ---------------------------------------------------------------------------
# Isolated so that build-only apt packages (autoconf, build-essential, cmake,
# nasm, yasm, texinfo, etc.) stay out of the final image layers. 
FROM nvcr.io/nvidia/cuda:12.9.1-devel-ubuntu24.04 AS ffmpeg-builder

SHELL ["/bin/bash", "-c"]

ENV FFMPEG_VERSION=8.0.1
{%- if ffmpeg_cuda %}
ENV NVCODEC_VERSION=13.0.19.0
{%- endif %}

RUN mkdir -p /tmp && chmod 1777 /tmp && \
    apt-get update && \
    apt-get install -y \
    libcrypt-dev \
    autoconf \
    automake \
    build-essential \
    cmake \
    libaom-dev \
    libass-dev \
    libdav1d-dev \
    libdrm-dev \
    libfreetype6-dev \
    libgnutls28-dev \
    libnuma-dev \
    libopenh264-dev \
    libtool \
    libva-dev \
    libvorbis-dev \
    libvpx-dev \
    libwebp-dev \
    nasm \
    pkg-config \
    texinfo \
    vainfo \
    yasm \
    zlib1g-dev \
    curl && \
{%- if ffmpeg_cuda %}
    curl -fsSL -o /tmp/nv-codec-headers.tar.gz https://github.com/FFmpeg/nv-codec-headers/releases/download/n${NVCODEC_VERSION}/nv-codec-headers-${NVCODEC_VERSION}.tar.gz && \
    tar xzvf /tmp/nv-codec-headers.tar.gz -C /tmp/ && \
    cd /tmp/nv-codec-headers-${NVCODEC_VERSION} && \
    make && \
    make install && \
{%- endif %}
    curl -fsSL -o /tmp/ffmpeg-snapshot.tar.bz2 https://www.ffmpeg.org/releases/ffmpeg-${FFMPEG_VERSION}.tar.bz2 && \
    tar xjvf /tmp/ffmpeg-snapshot.tar.bz2 -C /tmp/ && \
    cd /tmp/ffmpeg-${FFMPEG_VERSION} && \
{%- if ffmpeg_cuda %}
    PATH="/usr/local/cuda/bin:$PATH" \
{%- endif %}
    ./configure \
    --prefix=/opt/ffmpeg \
{%- if ffmpeg_cuda %}
    --enable-nonfree \
    --enable-cuda-nvcc \
    --enable-libnpp \
{%- endif %}
    --enable-libopenh264 \
    --enable-libaom \
    --enable-libdav1d \
    --enable-libvorbis \
    --enable-libvpx \
    --enable-libwebp \
    --enable-vaapi \
{%- if ffmpeg_cuda %}
    --extra-cflags=-I/usr/local/cuda/include \
    --extra-ldflags=-L/usr/local/cuda/lib64 \
{%- endif %}
    --extra-libs=-lpthread \
    --extra-libs=-lm \
    --disable-static \
    --enable-shared \
    --disable-doc \
    --disable-debug && \
    make -j$(nproc) && \
    make install && \
    ldconfig

# Install pixi with curl into /opt/pixi without modifying PATH
RUN curl -fsSL https://pixi.sh/install.sh | PIXI_HOME=/opt/pixi PIXI_NO_PATH_UPDATE=1 sh

# ---------------------------------------------------------------------------
# Main stage - do not change this image without also changing the builder image.
# To keep dynamic libraries in sync they should be the same version
# ---------------------------------------------------------------------------
FROM nvcr.io/nvidia/cuda:12.9.1-devel-ubuntu24.04 AS main

SHELL ["/bin/bash", "-c"]
ENV NVIDIA_DRIVER_CAPABILITIES=compute,video,utility
ENV TZ=America/Los_Angeles
# Get system level packages
RUN apt-get update \
    && apt-get install --option=Dpkg::Options::=--force-confdef -y \
    # Needed for opencv
    libsm6 libxext6 \
    # Needed because the certs age out sometimes?
    ca-certificates \
    # Needed for NVIDIA wheel pre-download during pixi install
    curl \
{%- if nsight %}
    # Needed for cuda profiling
    nsight-systems-2025.3.2 \
{%- endif %}
    # Needed to copy model weights using rsync
    rsync \
    # Runtime libraries for ffmpeg (shared libs it links against)
    libaom3 \
    libass9 \
    libdav1d7 \
    libdrm2 \
    libfreetype6 \
    libgnutls30t64 \
    libnuma1 \
    libopenh264-7 \
    libva2 \
    libva-drm2 \
    libvorbis0a libvorbisenc2 \
    libvpx9 \
    libwebp7 \
    libwebpmux3 \
    # Refresh GPG-related base packages without reintroducing full build tooling
    keyboxd gpgv gpgsm gpgconf gpg-agent \
    binutils openssl libsqlite3-0 \
    && update-ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Copy ffmpeg from the builder stage (installed to /opt/ffmpeg to avoid collisions)
COPY --from=ffmpeg-builder /opt/ffmpeg /opt/ffmpeg
RUN echo "/opt/ffmpeg/lib" > /etc/ld.so.conf.d/ffmpeg.conf && \
    ldconfig && \
    /opt/ffmpeg/bin/ffmpeg -version > /dev/null && \
    /opt/ffmpeg/bin/ffprobe -version > /dev/null

# Triton 3.6+ looks for a separate "ptxas-blackwell" binary on Blackwell GPUs
# (arch >= 100). The CUDA toolkit ships a single ptxas that already supports
# Blackwell, so a symlink is sufficient.
RUN ln -sf /usr/local/cuda/bin/ptxas /usr/local/cuda/bin/ptxas-blackwell

# Copy pixi binary from the builder stage
COPY --from=ffmpeg-builder /opt/pixi/bin/pixi /usr/local/bin/pixi

# Common ENV variables needed by some ML libs
ENV AM_I_DOCKER=True \
    BUILD_WITH_CUDA=True \
    TORCH_CUDA_ARCH_LIST="8.0;8.6;9.0;10.0+PTX" \
    CUDA_HOME="/usr/local/cuda" \
    CUDA_PATH="/usr/local/cuda" \
    PATH="/opt/ffmpeg/bin:/usr/local/cuda/bin:${PATH}" \
    CPATH="/usr/local/cuda/include" \
    LIBRARY_PATH="/usr/local/cuda/lib64:${LIBRARY_PATH:-}" \
    LD_LIBRARY_PATH="/usr/local/cuda/lib64:${LD_LIBRARY_PATH:-}" \
    XFORMERS_IGNORE_FLASH_VERSION_CHECK="1" \
    VLLM_WORKER_MULTIPROC_METHOD="spawn" \
    VLLM_USE_V1="1"

# Disable Ray log dedup
ENV RAY_DEDUP_LOGS=0 \
    RAY_EXPERIMENTAL_NOSET_CUDA_VISIBLE_DEVICES=1 \
    RAY_MAX_LIMIT_FROM_API_SERVER=40000 \
    RAY_MAX_LIMIT_FROM_DATA_SOURCE=40000 \
    RAY_DEFAULT_OBJECT_STORE_MAX_MEMORY_BYTES=800000000000 \
    RAY_DEFAULT_OBJECT_STORE_MEMORY_PROPORTION=0.4 \
    RAY_gcs_rpc_server_connect_timeout_s=30 \
    RAY_gcs_rpc_server_reconnect_timeout_s=180 \
    RAY_WARN_BLOCKING_GET_INSIDE_ASYNC=0 \
    XENNA_RAY_METRICS_PORT=9002

# boto3 & pbss
ENV AWS_REQUEST_CHECKSUM_CALCULATION='when_required'

# Set a bunch of env vars so that we cache weights in a workspace
ENV DEFAULT_WORKSPACE_LOC="/config/default_workspace"
ENV HF_HOME="${DEFAULT_WORKSPACE_LOC}/weights/hf_home/" \
    LAION_CACHE_HOME="${DEFAULT_WORKSPACE_LOC}/weights/laion_cache/"

# Set up pixi environments
COPY --chown=1000:1000 pixi.toml pixi.lock {{code_dir_str}}/

# ============================================================================
# NVIDIA CUDA Wheel Pre-download & pixi.lock Patching
# ============================================================================
#
# Problem:
#   pixi embeds uv as a compiled Rust library that hardcodes a 30-second HTTP
#   timeout for package downloads. This timeout CANNOT be configured:
#     - UV_HTTP_TIMEOUT env var is ignored (pixi overrides it internally)
#     - find-links / extra-index-urls are ignored during --frozen install
#       (pixi uses the exact download URLs baked into pixi.lock)
#
#   Large NVIDIA CUDA wheels (100-800 MB each) hosted on pypi.nvidia.com
#   regularly exceed 30 seconds to download, causing pixi install to fail.
#
# Solution:
#   1. Parse pixi.lock for all pypi.nvidia.com wheel URLs
#   2. Pre-download them with curl (5-minute timeout, 5 retries)
#   3. Patch pixi.lock in-place: replace remote URLs with file:// paths
#   4. pixi install --frozen reads the patched lockfile and loads wheels locally
#
# The pre-downloaded wheels live in a BuildKit cache mount (/pixi-cache/)
# which persists across builds and does NOT bloat the Docker image layers.
#
#   +------------------+       +-------------------+       +---------------------+
#   |   pixi.lock      | grep  | pypi.nvidia.com   | curl  | /pixi-cache/        |
#   |   (lockfile)     +------>| wheel URLs        +------>| nvidia-wheels/*.whl |
#   +------------------+       +-------------------+       +---------------------+
#                                                                   |
#   +------------------+   sed replaces remote URLs                 |
#   |   pixi.lock      |   with file:///pixi-cache/nvidia-wheels/  |
#   |   (patched)      +<------------------------------------------+
#   +------------------+
#          |
#          |  pixi install --frozen
#          v
#   +------------------+
#   |  local .whl read |  (no network, no timeout)
#   +------------------+
# ============================================================================
RUN --mount=type=cache,target=/pixi-cache \
    mkdir -p /pixi-cache/nvidia-wheels && \
    cd {{code_dir_str}} && \
    grep -oP 'https://pypi\.nvidia\.com/[^\s"]+\.whl' pixi.lock | sort -u | while read -r url; do \
        if [[ ! "$url" =~ ^https://pypi\.nvidia\.com/[a-zA-Z0-9/_.-]+\.whl$ ]]; then \
            echo "WARNING: Skipping invalid URL: $url"; \
            continue; \
        fi; \
        filename=$(basename "$url") && \
        echo "Pre-downloading: $filename" && \
        curl -fsSL --retry 5 --retry-delay 3 --max-time 300 -C - -o "/pixi-cache/nvidia-wheels/$filename" "$url" || \
            echo "WARNING: Failed to download $filename (will retry during pixi install)"; \
    done && \
    echo "=== Pre-downloaded $(ls -1 /pixi-cache/nvidia-wheels/*.whl 2>/dev/null | wc -l) NVIDIA wheels ===" && \
    patched=0 && \
    for whl in /pixi-cache/nvidia-wheels/*.whl; do \
        [ -f "$whl" ] || continue; \
        filename=$(basename "$whl") && \
        if grep -q "$filename" pixi.lock; then \
            sed -i "s|https://pypi\.nvidia\.com/[^\"]*/${filename}\\b|file:///pixi-cache/nvidia-wheels/${filename}|g" pixi.lock && \
            patched=$((patched + 1)); \
        fi; \
    done && \
    echo "=== Patched $patched NVIDIA wheel URLs in pixi.lock to use local files ==="

# If we install all the environments in a single layer, it's over 20GB and will cause slurm/NVCF to timeout pulling the
# layer. Since the cuml environment is large and needs non-overlapping RAPIDS packages, we install it separately.
#
# BuildKit cache mount: The --mount=type=cache,target=/pixi-cache is kept here so that
# the pre-downloaded NVIDIA wheels (patched into pixi.lock as file:///pixi-cache/nvidia-wheels/...)
# are accessible during pixi install.
#
# Retry logic: pixi install can fail due to transient network errors (connection resets, timeouts).
# We retry up to 10 times with a 3-second backoff to handle these flakes.
#
# IMPORTANT: Do NOT set RATTLER_CACHE_DIR or UV_CACHE_DIR to the BuildKit cache mount.
# Rattler uses hardlinks from its package cache into each environment directory. When
# multiple environments share packages (e.g. torch across default, unified, transformers),
# the hardlinked files share a single inode and Docker stores the data ONCE in the layer tar.
# Redirecting the cache to a mount (different filesystem) breaks hardlinks -- rattler falls
# back to full copies, duplicating multi-GB packages across every environment (~8GB -> ~21GB).
# Instead, let rattler use its default on-disk cache and clean it within the same RUN layer.
RUN --mount=type=cache,target=/pixi-cache \
    cd {{code_dir_str}} && \
{%- if verbose %}
    echo "=== pixi version ===" && pixi --version && \
{%- endif %}
    export CONDA_OVERRIDE_CUDA=12.9.1 && \
{%- if verbose %}
    export RUST_LOG=uv=debug && \
    export UV_NO_PROGRESS=1 && \
    export NO_COLOR=1 && \
{%- endif %}
    export CUDA_PATH="/usr/local/cuda" && \
    success=false && \
    for attempt in {1..10}; do \
        echo "=== pixi install attempt $attempt/10 ===" && \
        if pixi install {{ '-v' if verbose else '' }} -e default -e {{ envs | reject('equalto', 'cuml') | join(' -e ') }} --frozen 2>&1; then \
            success=true && break; \
        fi; \
        echo "pixi install attempt $attempt/10 failed, retrying in 3s..." && sleep 3; \
    done && \
    pixi clean cache -y && \
    $success

# Install the cuml environment separately if requested.
{% if 'cuml' in envs %}
RUN --mount=type=cache,target=/pixi-cache \
    cd {{code_dir_str}} && \
    export CONDA_OVERRIDE_CUDA=12.9.1 && \
{%- if verbose %}
    export RUST_LOG=uv=debug && \
    export UV_NO_PROGRESS=1 && \
    export NO_COLOR=1 && \
{%- endif %}
    success=false && \
    for attempt in {1..10}; do \
        echo "=== pixi install cuml attempt $attempt/10 ===" && \
        if pixi install {{ '-v' if verbose else '' }} -e cuml --frozen 2>&1; then \
            success=true && break; \
        fi; \
        echo "pixi install attempt $attempt/10 failed, retrying in 3s..." && sleep 3; \
    done && \
    pixi clean cache -y && \
    $success
{% endif %}

# Run any hacky post-install script for each environment
COPY package/cosmos_curate/envs/ /tmp/cosmos_curate_build_envs
{% for env in post_install_envs %}
RUN cd {{code_dir_str}} && \
    pixi run -e {{ env }} bash /tmp/cosmos_curate_build_envs/{{ env }}/post_install.sh
{% endfor %}

# For cosmos-xenna development
# For every environment, uninstall cosmos-xenna and then reinstall from local build.
{% if use_local_xenna_build %}
COPY cosmos-xenna /tmp/cosmos-xenna
{% set all_envs = envs + ['default'] %}
{% for env in all_envs %}
RUN cd {{code_dir_str}} && \
    pixi run -e {{ env }} pip uninstall -y cosmos-xenna && \
    pixi run -e {{ env }} pip install /tmp/cosmos-xenna
{% endfor %}
{% endif %}

# Copy the video pipeline code
COPY --chown=1000:1000 cosmos_curate {{code_dir_str}}/cosmos_curate
COPY --chown=1000:1000 tests {{code_dir_str}}/tests
COPY --chown=1000:1000 pytest.ini .coveragerc {{code_dir_str}}/

# Copy additional code paths into the container
{% for code_path in code_paths %}
COPY --chown=1000:1000 {{code_path}} {{code_dir_str}}/{{code_path}}
{% endfor %}

# Debug env vars
# ENV PYTHON_LOG=debug RUST_LOG=debug VLLM_LOG_LEVEL=DEBUG

# Expose port for FastAPI & Ray
EXPOSE 8000 6379

WORKDIR {{code_dir_str}}

CMD ["pixi", "run", "python", "cosmos_curate/scripts/onto_nvcf.py", "--helm", "True"]
